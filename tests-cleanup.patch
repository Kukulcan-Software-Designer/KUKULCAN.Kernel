diff --git a/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Behaviors/ValidationBehaviorIntegrationTests.cs b/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Behaviors/ValidationBehaviorIntegrationTests.cs
--- a/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Behaviors/ValidationBehaviorIntegrationTests.cs
+++ b/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Behaviors/ValidationBehaviorIntegrationTests.cs
@@ -1,0 +1,117 @@
+using System;
+using System.Threading;
+using System.Threading.Tasks;
+using FluentAssertions;
+using FluentValidation;
+using FluentValidation.Results;
+using Xunit;
+using KUKULCAN.Kernel.Infrastructure.Behaviors;
+using KUKULCAN.Kernel.Domain.Result;
+using MediatR;
+
+namespace KUKULCAN.Kernel.Integration.Tests.Infrastructure.Behaviors
+{
+    public class ValidationBehaviorIntegrationTests
+    {
+        private sealed class SampleRequest : IRequest<Result> { }
+
+        private sealed class PassingValidator : IValidator<SampleRequest>
+        {
+            public FluentValidation.Results.ValidationResult Validate(ValidationContext<SampleRequest> context) => new FluentValidation.Results.ValidationResult();
+            public Task<FluentValidation.Results.ValidationResult> ValidateAsync(ValidationContext<SampleRequest> context, CancellationToken cancellation = default) => Task.FromResult(new FluentValidation.Results.ValidationResult());
+            public IValidatorDescriptor CreateDescriptor() => throw new NotImplementedException();
+        }
+
+        private sealed class FailingValidator : IValidator<SampleRequest>
+        {
+            public FluentValidation.Results.ValidationResult Validate(ValidationContext<SampleRequest> context)
+                => new FluentValidation.Results.ValidationResult(new[] { new ValidationFailure("Name", "Invalid") });
+            public Task<FluentValidation.Results.ValidationResult> ValidateAsync(ValidationContext<SampleRequest> context, CancellationToken cancellation = default)
+                => Task.FromResult(new FluentValidation.Results.ValidationResult(new[] { new ValidationFailure("Name", "Invalid") }));
+            public IValidatorDescriptor CreateDescriptor() => throw new NotImplementedException();
+        }
+
+        [Fact]
+        public async Task When_NoValidators_NextIsInvoked()
+        {
+            var behavior = new ValidationBehavior<SampleRequest, Result>(Array.Empty<IValidator<SampleRequest>>());
+            var invoked = false;
+            RequestHandlerDelegate<Result> Next = () => { invoked = true; return Task.FromResult(Result.Ok()); };
+
+            var result = await behavior.Handle(new SampleRequest(), Next, CancellationToken.None);
+            invoked.Should().BeTrue();
+            result.IsSuccess.Should().BeTrue();
+        }
+
+        [Fact]
+        public async Task When_ValidatorsFail_ReturnsValidationFailure()
+        {
+            var behavior = new ValidationBehavior<SampleRequest, Result>(new[] { new FailingValidator() });
+            RequestHandlerDelegate<Result> Next = () => Task.FromResult(Result.Ok());
+
+            var result = await behavior.Handle(new SampleRequest(), Next, CancellationToken.None);
+
+            result.IsFailure.Should().BeTrue();
+            result.Error.Message.Should().Contain("Validation failed");
+        }
+    }
+}
+
diff --git a/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Pagination/PagedResultIntegrationTests.cs b/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Pagination/PagedResultIntegrationTests.cs
--- a/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Pagination/PagedResultIntegrationTests.cs
+++ b/Tests/KUKULCAN.Kernel.Integration.Tests/Infrastructure/Pagination/PagedResultIntegrationTests.cs
@@ -1,0 +1,102 @@
+using System.Linq;
+using FluentAssertions;
+using Xunit;
+using KUKULCAN.Kernel.Infrastructure.Pagination;
+
+namespace KUKULCAN.Kernel.Integration.Tests.Infrastructure.Pagination
+{
+    public class PagedResultIntegrationTests
+    {
+        [Fact]
+        public void Create_ComputesPaginationMetadata()
+        {
+            var items = Enumerable.Range(1, 5).ToList();
+            var req = new PaginationRequest { Page = 2, PageSize = 3 };
+            var page = PagedResult<int>.Create(items, totalCount: 8, req);
+
+            page.TotalCount.Should().Be(8);
+            page.Page.Should().Be(2);
+            page.PageSize.Should().Be(3);
+            page.TotalPages.Should().Be(3);
+            page.HasNextPage.Should().BeTrue();
+            page.HasPreviousPage.Should().BeTrue();
+            page.FirstItemIndex.Should().Be(4);
+            page.LastItemIndex.Should().Be(6);
+        }
+
+        [Fact]
+        public void Map_ProjectItems()
+        {
+            var items = new[] { 1, 2 };
+            var req = new PaginationRequest { Page = 1, PageSize = 10 };
+            var page = PagedResult<int>.Create(items, totalCount: 2, req);
+            var mapped = page.Map(i => i.ToString());
+
+            mapped.Items.Should().ContainInOrder("1", "2");
+            mapped.TotalCount.Should().Be(page.TotalCount);
+        }
+
+        [Fact]
+        public void Empty_ReturnsZeroCountsAndIndexes()
+        {
+            var req = new PaginationRequest { Page = 1, PageSize = 10 };
+            var empty = PagedResult<int>.Empty(req);
+
+            empty.Items.Should().BeEmpty();
+            empty.TotalCount.Should().Be(0);
+            empty.TotalPages.Should().Be(0);
+            empty.FirstItemIndex.Should().Be(0);
+            empty.LastItemIndex.Should().Be(0);
+        }
+
+        [Fact]
+        public void Map_Throws_WhenMapperNull()
+        {
+            var items = new[] { 1 };
+            var req = new PaginationRequest { Page = 1, PageSize = 10 };
+            var page = PagedResult<int>.Create(items, totalCount: 1, req);
+
+            Action act = () => page.Map<string>(null!);
+            act.Should().Throw<ArgumentNullException>();
+        }
+    }
+}
+
