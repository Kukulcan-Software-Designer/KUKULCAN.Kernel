@@ -1,0 +1,72 @@
+using System;
+using FluentAssertions;
+using Xunit;
+using KUKULCAN.Kernel.Domain.ValueObjects;
+
+namespace KUKULCAN.Kernel.Integration.Tests.Domain.ValueObjects
+{
+    public class MoneyIntegrationTests
+    {
+        [Fact]
+        public void Create_InvalidAmount_ReturnsFailure()
+        {
+            var res = Money.Create(-1m, "EUR");
+            res.IsFailure.Should().BeTrue();
+        }
+
+        [Fact]
+        public void Create_InvalidCurrency_ReturnsFailure()
+        {
+            var res = Money.Create(10m, "EU");
+            res.IsFailure.Should().BeTrue();
+        }
+
+        [Fact]
+        public void Arithmetic_AddSubtractSameCurrency_Works()
+        {
+            var a = Money.Create(10m, "EUR").Value;
+            var b = Money.Create(5m, "EUR").Value;
+
+            var sum = a + b;
+            sum.Amount.Should().Be(15m);
+            sum.CurrencyCode.Should().Be("EUR");
+
+            var diff = a - b;
+            diff.Amount.Should().Be(5m);
+        }
+
+        [Fact]
+        public void Arithmetic_Throws_OnDifferentCurrencies()
+        {
+            var a = Money.Create(10m, "EUR").Value;
+            var b = Money.Create(5m, "USD").Value;
+
+            Action add = () => { var x = a + b; };
+            add.Should().Throw<InvalidOperationException>().WithMessage("*different currencies*");
+
+            Action compare = () => { var gt = a > b; };
+            compare.Should().Throw<InvalidOperationException>();
+        }
+
+        [Fact]
+        public void Subtract_Throws_WhenResultNegative()
+        {
+            var a = Money.Create(3m, "EUR").Value;
+            var b = Money.Create(5m, "EUR").Value;
+
+            Action act = () => { var r = a - b; };
+            act.Should().Throw<InvalidOperationException>().WithMessage("*result would be negative*");
+        }
+
+        [Fact]
+        public void PercentageAndRound_WorkAsExpected()
+        {
+            var a = Money.Create(100m, "USD").Value;
+            var pct = a.Percentage(12.5m);
+            pct.Amount.Should().BeApproximately(12.5m, 0.000001m);
+
+            var rounded = (a * 1.2345m).Round(2);
+            rounded.ToString().Should().Match("* USD");
+        }
+    }
+}
