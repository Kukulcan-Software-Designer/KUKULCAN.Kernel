diff --git a/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/ArrayExtensionsIntegrationTests.cs b/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/ArrayExtensionsIntegrationTests.cs
--- a/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/ArrayExtensionsIntegrationTests.cs
+++ b/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/ArrayExtensionsIntegrationTests.cs
@@ -1,0 +1,44 @@
+using System;
+using FluentAssertions;
+using Xunit;
+using KUKULCAN.Kernel.Extensions;
+
+namespace KUKULCAN.Kernel.Integration.Tests.Extensions
+{
+    public class ArrayExtensionsIntegrationTests
+    {
+        [Fact]
+        public void Add_AppendsItem_WhenPrependFalse()
+        {
+            var arr = new[] { 1, 2, 3 };
+            var res = arr.Add(4);
+            res.Should().Equal(new[] { 1, 2, 3, 4 });
+        }
+
+        [Fact]
+        public void Add_PrependsItem_WhenPrependTrue()
+        {
+            var arr = new[] { 1, 2, 3 };
+            var res = arr.Add(0, true);
+            res.Should().Equal(new[] { 0, 1, 2, 3 });
+        }
+
+        [Fact]
+        public void Add_ThrowsOnNullTarget()
+        {
+            int[]? arr = null;
+            Action act = () => arr!.Add(1);
+            act.Should().Throw<ArgumentNullException>();
+        }
+
+        [Fact]
+        public void Add_OnEmptyArray_WorksForPrependAndAppend()
+        {
+            var empty = Array.Empty<int>();
+            var appended = empty.Add(1);
+            appended.Should().Equal(new[] { 1 });
+
+            var prepended = empty.Add(1, true);
+            prepended.Should().Equal(new[] { 1 });
+        }
+    }
+}
+
diff --git a/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/DateExtensionsIntegrationTests.cs b/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/DateExtensionsIntegrationTests.cs
--- a/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/DateExtensionsIntegrationTests.cs
+++ b/Tests/KUKULCAN.Kernel.Integration.Tests/Extensions/DateExtensionsIntegrationTests.cs
@@ -1,0 +1,37 @@
+using System;
+using System.Globalization;
+using FluentAssertions;
+using Xunit;
+using KUKULCAN.Kernel.Extensions;
+
+namespace KUKULCAN.Kernel.Integration.Tests.Extensions
+{
+    public class DateExtensionsIntegrationTests
+    {
+        [Fact]
+        public void ParseExactOrDefault_ParsesValidString()
+        {
+            var parsed = DateExtensions.ParseExactOrDefault("20260301", "yyyyMMdd", CultureInfo.InvariantCulture, null);
+            parsed.Should().HaveValue();
+            parsed.Value.Year.Should().Be(2026);
+            parsed.Value.Month.Should().Be(3);
+            parsed.Value.Day.Should().Be(1);
+        }
+
+        [Fact]
+        public void ParseExactOrDefault_ReturnsDefaultOnInvalid()
+        {
+            var def = new DateTime(2000, 1, 1);
+            var parsed = DateExtensions.ParseExactOrDefault("bad", "yyyyMMdd", CultureInfo.InvariantCulture, def);
+            parsed.Should().Be(def);
+        }
+
+        [Fact]
+        public void ToDateFormatWithTimeIso8601_FormatsCorrectly()
+        {
+            var dt = new DateTime(2026, 3, 1, 10, 30, 0, DateTimeKind.Utc);
+            var formatted = dt.ToDateFormatWithTimeIso8601();
+            formatted.Should().StartWith("2026-03-01T10:30:00");
+        }
+    }
+}
